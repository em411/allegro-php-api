{
    "name": "em411/allegro-php-api",
    "description": "Auto-generated client for Allegro API",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Em411\\Allegro\\Api\\": "generated/",
            "Em411\\Allegro\\": "src/"
        }
    },
    "require": {
        "php": "^7.4 || ^8.0",
        "ext-curl": "*",
        "jane-php/open-api-runtime": "^7.5",
        "php-http/client-common": "^2.0",
        "php-http/discovery": "^1.20",
        "php-http/multipart-stream-builder": "^1.4",
        "psr/http-client-implementation": "*",
        "symfony/http-client": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": "true"
        }
    },
    "require-dev": {
        "jane-php/open-api-3": "^7.5",
        "friendsofphp/php-cs-fixer": "^3.92"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        },
        "sort-packages": true
    }
}
